# Edutrack Environment Configuration Template
# Copy this file to '.env' and fill in your values for production/local running.

# Flask configuration profile: dev | prod | test
FLASK_ENV=dev

# Flask secret key (Use a secure random string in production)
SECRET_KEY=edutrack-dev-key-change-for-production

# Database URI Connection String
# For local SQLite: (leave commented out to use default instance/edutrack.db)
# DATABASE_URL=sqlite:///instance/edutrack.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://db_user:db_password@db_host:5432/edutrack_db

# Enforce secure cookies (Set to True if running HTTPS in production)
SESSION_COOKIE_SECURE=False

# Default Campus GPS settings (optional overrides)
# EDUTRACK_CAMPUS_LAT=20.5937
# EDUTRACK_CAMPUS_LNG=78.9629
# EDUTRACK_CAMPUS_RADIUS_M=500
